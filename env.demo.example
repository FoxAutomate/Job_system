# Osobny projekt Vercel (np. branch `demo`) — nie podłączaj pod produkcyjny deploy głównej strony.
# Produkcja: nie ustawiaj DEMO_MODE ani NEXT_PUBLIC_DEMO.

DEMO_MODE=true
NEXT_PUBLIC_DEMO=true

AUTH_SECRET=
# NextAuth: pole logowania to email — użyj adresu, np.:
ADMIN_EMAIL=admin@canningbrothers-careers.demo
# bcrypt hash hasła (np. admin123); wygeneruj: npx bcrypt-cli lub osobny skrypt
ADMIN_PASSWORD_HASH=

# Demo działa bez bazy — nie ustawiaj produkcyjnego DATABASE_URL / BLOB_*.
